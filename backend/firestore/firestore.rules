rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isParentOf(childId) {
      return signedIn() && exists(/databases/$(database)/documents/children/$(childId)) &&
        get(/databases/$(database)/documents/children/$(childId)).data.parentId == request.auth.uid;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    match /users/{userId} {
      allow read, update, delete: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
    }

    match /children/{childId} {
      allow create: if signedIn() && request.resource.data.parentId == request.auth.uid;
      allow read, update, delete: if isParentOf(childId) || isAdmin();
    }

    match /brushingSessions/{sessionId} {
      allow create: if signedIn() && request.resource.data.childId is string && isParentOf(request.resource.data.childId);
      allow read: if isAdmin() || isParentOf(resource.data.childId);
      allow update, delete: if false;
    }

    match /gameSessions/{sessionId} {
      allow create: if signedIn() && request.resource.data.childId is string && isParentOf(request.resource.data.childId);
      allow read: if isAdmin() || isParentOf(resource.data.childId);
      allow update, delete: if false;
    }

    match /rewards/{rewardId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /challenges/{challengeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /leaderboard/{entryId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.resource.data.keys().hasOnly(['childId', 'nickname', 'avatar', 'points', 'level', 'updatedAt']) && isParentOf(request.resource.data.childId);
      allow delete: if isAdmin();
    }

    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}

